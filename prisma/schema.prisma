generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String?   @unique
  emailVerified DateTime?
  image        String?
  passwordHash String?

  plan                         UserPlan           @default(FREE)
  subscriptionStatus           SubscriptionStatus @default(NONE)
  stripeCustomerId             String?            @unique
  stripeSubscriptionId         String?            @unique
  subscriptionCurrentPeriodEnd DateTime?

  accounts     Account[]
  sessions     Session[]

  incomes      Income[]
  expenses     Expense[]
  investments  Investment[]
  loans        Loan[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Income {
  id         String   @id @default(cuid())
  userId     String

  title      String
  category   String
  amount     Decimal  @db.Decimal(12, 2)
  receivedAt DateTime
  frequency  String
  notes      String?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([receivedAt])
}

model Expense {
  id        String   @id @default(cuid())
  userId    String

  title     String
  category  String
  type      String
  amount    Decimal  @db.Decimal(12, 2)
  spentAt   DateTime
  notes     String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([spentAt])
}

model Investment {
  id             String   @id @default(cuid())
  userId         String

  assetName      String
  category       String
  investedAmount Decimal  @db.Decimal(12, 2)
  currentValue   Decimal  @db.Decimal(12, 2)
  investedAt     DateTime
  notes          String?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([investedAt])
}

model Loan {
  id               String    @id @default(cuid())
  userId           String

  title            String
  lenderName       String
  category         String
  principalAmount  Decimal   @db.Decimal(12, 2)
  remainingBalance Decimal   @db.Decimal(12, 2)
  monthlyPayment   Decimal   @db.Decimal(12, 2)
  interestRate     Decimal?  @db.Decimal(5, 2)
  dueDate          DateTime?
  status           String    @default("ACTIVE")

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([dueDate])
  @@index([status])
}